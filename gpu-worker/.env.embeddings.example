# Example: set this to your AMQP connection URL in the local .env.embeddings file.
RABBITMQ_URL=
GPU_WORKER_QUEUE=gpu.embeddings
GPU_WORKER_CONSUMER_TAG=gamingpc-gpu-worker-embeddings
GPU_WORKER_METRICS_ADDR=:9102
GPU_WORKER_COMMAND_ENABLED=true
GPU_WORKER_COMMAND=/home/jeppe/Documents/Kod/gpu-worker/scripts/run-embedding-job.sh
GPU_WORKER_JOB_DIR=/home/jeppe/Documents/Kod/gpu-worker/jobs
GPU_WORKER_JOB_TIMEOUT_SECONDS=0
HOMESERVER_IP=
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
GPU_WORKER_GAMING_PROCESSES=steam,steamwebhelper
GPU_WORKER_BLOCK_WHEN_GAMING=true
GPU_WORKER_BLOCK_WHEN_GPU_BUSY=true
GPU_WORKER_GPU_BUSY_THRESHOLD_PERCENT=85
GPU_WORKER_BLOCK_REQUEUE_DELAY_SECONDS=30
