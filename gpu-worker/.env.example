# Example: set this to your AMQP connection URL in the local .env file.
RABBITMQ_URL=
GPU_WORKER_QUEUE=gpu.whisper
GPU_WORKER_CONSUMER_TAG=gamingpc-gpu-worker
GPU_WORKER_METRICS_ADDR=:9101

# Dry-run mode acknowledges jobs without executing a local command.
GPU_WORKER_COMMAND_ENABLED=false
GPU_WORKER_COMMAND=
HOMESERVER_IP=
GPU_WORKER_JOB_TIMEOUT_SECONDS=0

# Optional blockers. Leave process list empty to disable gaming-process blocking.
GPU_WORKER_GAMING_PROCESSES=steam,steamwebhelper
GPU_WORKER_BLOCK_WHEN_GAMING=true
GPU_WORKER_BLOCK_WHEN_GPU_BUSY=true
GPU_WORKER_GPU_BUSY_THRESHOLD_PERCENT=85
GPU_WORKER_BLOCK_REQUEUE_DELAY_SECONDS=30
